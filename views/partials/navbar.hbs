<header class="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">
      <span class="logo-icon">🛍</span>
      <span>Shop<span class="logo-accent">EZ</span></span>
    </a>

    <nav class="navbar__links">
      <a href="/" class="nav-link">Home</a>
      <a href="/products" class="nav-link">Shop</a>
      <a href="/products?category=Electronics" class="nav-link">Electronics</a>
      <a href="/products?category=Fashion" class="nav-link">Fashion</a>
    </nav>

    <form class="navbar__search" action="/products" method="GET">
      <input type="text" name="q" placeholder="Search products..." class="search-input" value="">
      <button type="submit" class="search-btn">🔍</button>
    </form>

    <div class="navbar__actions">
      {{#if user}}
        <a href="/account" class="nav-action" title="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="nav-action__label">{{user.name}}</span>
        </a>
        <a href="/auth/logout" class="nav-action" title="Logout">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </a>
      {{else}}
        <a href="/auth/login" class="nav-action" title="Login">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="nav-action__label">Login</span>
        </a>
      {{/if}}
      <a href="/cart" class="nav-action cart-btn" title="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        {{#if cart}}
          {{#if cart.length}}
            <span class="cart-count">{{cartCount cart}}</span>
          {{/if}}
        {{/if}}
      </a>
    </div>

    <button class="mobile-menu-btn" onclick="toggleMenu()">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
