<div class="product-card">
  {{#if badge}}
    <span class="product-badge product-badge--{{badge}}">{{badge}}</span>
  {{/if}}
  <a href="/products/{{id}}" class="product-card__img-wrap">
    <img src="{{image}}" alt="{{name}}" class="product-card__img" loading="lazy">
  </a>
  <div class="product-card__body">
    <span class="product-category">{{category}}</span>
    <a href="/products/{{id}}" class="product-card__name">{{name}}</a>
    <div class="product-card__rating">
      <span class="stars">{{stars rating}}</span>
      <span class="review-count">({{reviews}})</span>
    </div>
    <div class="product-card__footer">
      <div class="product-price">
        <span class="price--current">${{formatPrice price}}</span>
        {{#if originalPrice}}
          {{#gt originalPrice price}}
            <span class="price--original">${{formatPrice originalPrice}}</span>
          {{/gt}}
        {{/if}}
      </div>
      <form action="/cart/add" method="POST">
        <input type="hidden" name="productId" value="{{id}}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="btn-add-cart" title="Add to cart">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        </button>
      </form>
    </div>
  </div>
</div>
