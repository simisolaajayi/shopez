<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">🛍 Shop<span class="logo-accent">EZ</span></div>
    <h1>Welcome Back</h1>
    <p class="auth-sub">Sign in to your account to continue shopping</p>

    <form action="/auth/login" method="POST" class="auth-form">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" required class="form-input" placeholder="you@example.com" value="demo@shopez.com">
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required class="form-input" placeholder="••••••••" value="demo1234">
      </div>
      <div class="form-row-between">
        <label class="checkbox-label">
          <input type="checkbox"> Remember me
        </label>
        <a href="#" class="link">Forgot password?</a>
      </div>
      <button type="submit" class="btn btn--primary btn--full btn--lg">Sign In →</button>
    </form>

    <div class="demo-box">
      <strong>Demo Credentials</strong>
      <p>Email: <code>demo@shopez.com</code></p>
      <p>Password: <code>demo1234</code></p>
    </div>

    <p class="auth-switch">Don't have an account? <a href="/auth/register" class="link">Create one →</a></p>
  </div>

  <div class="auth-visual">
    <div class="auth-promo">
      <h2>Shop Thousands of Products</h2>
      <ul>
        <li>✓ Free shipping on orders over $50</li>
        <li>✓ Easy 30-day returns</li>
        <li>✓ Exclusive member deals</li>
        <li>✓ Order tracking</li>
      </ul>
    </div>
  </div>
</div>
